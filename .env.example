# Copy this file to .env and fill in your values.
# Deploy (SSH)
VITE_SSH_USERNAME=
VITE_SSH_HOSTNAME=
VITE_SSH_PASSWORD=
VITE_FOLDER_NAME=ha-dashboard

# Home Assistant connection (dev + sync)
VITE_HA_URL=
VITE_HA_TOKEN=

# Dishwasher cycle history: full URL to an API that GET/PUTs dishwasher_feedback.json (optional)
# If unset, the dishwasher card still shows live state and programme/short selects; cycle history is hidden.
# VITE_DISHWASHER_FEEDBACK_URL=

# Dryer cycle history: full URL to an API that GET/PUTs dryer_feedback.json (optional)
# If unset, the dryer card still shows live state and programme select; cycle history is hidden.
# VITE_DRYER_FEEDBACK_URL=
